generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id            String   @id @default(cuid())
  email         String?  @unique
  phone         String?  @unique
  passwordHash  String
  name          String?
  avatar        String?
  role          String   @default("user") // user | admin
  // subscription
  plan          String   @default("free") // free | monthly | quarterly | yearly
  planExpire    DateTime?
  // quotas
  dailyLimit    Int      @default(5)
  usedToday     Int      @default(0)
  lastUseDate   DateTime?
  // session invalidation
  tokenVersion  Int      @default(0)
  // account deletion (soft-delete / anonymization timestamp)
  deletedAt     DateTime?
  // timestamps
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  orders        Order[]
  toolRecords   ToolRecord[]

  @@map("users")
}

model Order {
  id              String   @id @default(cuid())
  userId          String
  orderNo         String   @unique
  plan            String   // monthly | quarterly | yearly
  amount          Decimal  @db.Decimal(10, 2)
  status          String   @default("pending") // pending | paid | failed | refunded
  paymentMethod   String   @default("alipay")
  tradeNo         String?  // alipay trade no
  paidAt          DateTime?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  user            User     @relation(fields: [userId], references: [id], onDelete: NoAction)

  @@index([userId])
  @@index([status])
  @@map("orders")
}

model ToolRecord {
  id          String   @id @default(cuid())
  userId      String
  toolId      String
  input       String
  output      String
  tokensUsed  Int      @default(0)
  createdAt   DateTime @default(now())

  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([userId, createdAt])
  @@index([createdAt])
  @@map("tool_records")
}

model VerificationCode {
  id        String   @id @default(cuid())
  target    String   // email or phone
  code      String
  type      String   // register | reset
  expiresAt DateTime
  used      Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([target])
  @@index([target, createdAt])
  @@map("verification_codes")
}
