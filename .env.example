# Database - PostgreSQL (阿里云 RDS PostgreSQL)
# 开发环境使用本地 PostgreSQL，生产环境替换为阿里云 RDS 连接串
DATABASE_URL="postgresql://user:password@localhost:5432/aitoolshelper?schema=public"

# Auth
JWT_SECRET="generate-with-openssl-rand-base64-32"
JWT_EXPIRES="7d"

# DeepSeek AI
DEEPSEEK_API_KEY=""
DEEPSEEK_BASE_URL="https://api.deepseek.com"

# Alipay - 密钥文件路径
ALIPAY_APP_ID=""
ALIPAY_APP_PRIVATE_KEY_PATH=""
ALIPAY_ALIPAY_PUBLIC_KEY_PATH=""
ALIPAY_SIGN_TYPE="RSA2"
ALIPAY_GATEWAY="https://openapi.alipay.com/gateway.do"
ALIPAY_NOTIFY_URL=""
ALIPAY_RETURN_URL=""

# Email (SMTP) - 推荐 163邮箱（开启SMTP服务后获取客户端授权码）
# 详细配置见 docs/SETUP.md 第3节
SMTP_HOST="smtp.163.com"
SMTP_PORT="465"
SMTP_USER=""
SMTP_PASS=""
SMTP_FROM=""

# App
APP_NAME="AI工具箱"
APP_URL="http://localhost:3000"
NODE_ENV="development"
